# ─────────────────────────────────────────────────────────────────
#  LogiBrain — Variables de entorno (EJEMPLO)
#  Copia este archivo como ".env" y completa los valores reales.
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=logibrain
POSTGRES_PASSWORD=logibrain123
POSTGRES_DB=logibrain_db

# URL completa (usada por SQLAlchemy y LangChain)
DATABASE_URL=postgresql://logibrain:logibrain123@localhost:5432/logibrain_db

# ── pgAdmin ──────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@logibrain.com
PGADMIN_PASSWORD=admin123

# ── LLM para el Agente Text-to-SQL ──────────────────────────────
# Proveedor: Groq — llama-3.3-70b-versatile (tier gratuito)
# Obtén tu clave en: https://console.groq.com (sin tarjeta de crédito)
GROQ_API_KEY=gsk_your-groq-key-here

# Alternativa OpenAI (descomenta y ajusta sql_assistant.py):
# OPENAI_API_KEY=sk-your-openai-key-here

# Alternativa Gemini (descomenta y ajusta sql_assistant.py):
# GOOGLE_API_KEY=your-google-api-key-here
